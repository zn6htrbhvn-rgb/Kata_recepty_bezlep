rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Pravidla pro kolekci 'recipes'
    match /recipes/{document=**} {
      // Čtení je povoleno všem návštěvníkům webu
      allow read: if true;
      
      // Zápis (vytváření, úpravy, mazání) je povolen pouze přihlášeným administrátorům
      allow write: if request.auth != null;
    }
  }
}
